# =============================================================================
# dbt-contracts Environment Configuration
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# =============================================================================

# --- Anthropic ---
# Required for contract generation via Claude API.
# SECURITY: This key must only exist as a server-side environment variable.
# It must never appear in frontend code, client-side bundles, or API responses.
ANTHROPIC_API_KEY=sk-ant-...

# --- Supabase ---
# Get these from your Supabase project settings > API.
# SUPABASE_ANON_KEY is safe to use in frontend code (row-level security applies).
# SUPABASE_SERVICE_ROLE_KEY bypasses RLS — keep it server-side only.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# --- Application ---
# Set to "production" in Railway, "development" locally.
ENVIRONMENT=development

# Primary frontend origin — used as the fallback CORS origin when
# CORS_ORIGINS is not explicitly set, and enforced in production to ensure
# no localhost origin is permitted.
FRONTEND_URL=https://your-app.vercel.app

# CORS origins — comma-separated list of allowed frontend origins.
# Development: include both Vite ports.
# Production: set ONLY the Vercel domain — the application strips localhost
# origins automatically when ENVIRONMENT=production.
# Example (development): http://localhost:5173,http://localhost:3000
# Example (production):  https://dbt-contracts.vercel.app
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Rate Limiting ---
# Max contract generation requests per IP per hour (free tier).
# The rate-limit counter key is the X-Forwarded-For header value, which
# Railway sets to the real client IP.
RATE_LIMIT_PER_HOUR=10

# --- File Uploads ---
# Maximum manifest.json upload size in bytes.
# Requirement: 10 MB maximum. Increase only with justification.
MAX_UPLOAD_SIZE_BYTES=10485760

# Maximum contract YAML body size for /validate and /export endpoints (bytes).
# Default: 100 KB. Prevents oversized payloads reaching the YAML parser.
MAX_CONTRACT_YAML_BYTES=102400

# --- Optional: Telemetry ---
# Enables anonymous usage statistics (model count, generation count).
ENABLE_TELEMETRY=true

# --- Railway (auto-injected, do not set manually) ---
# PORT=8000
# RAILWAY_ENVIRONMENT=production
